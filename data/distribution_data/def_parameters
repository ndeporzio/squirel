# default parameters for all runs. omega_m, not omega_c held fixed (for now. If fixing a_eq is desired, we will change omega_cdm accordingly)
# Similarly, Hubble not theta_s is held fixed here. Subject to change depending on CL's
# runCLASS.py will modify additonal NCDM parameters as needed for each cosmology

output = tCl,pCl,lCl,mPk
lensing = yes                     # Should the Cls from above be lensed for CMB?
non_linear =                      # Select 'halofit' or 'HMCode' or leave blank
l_max_scalars = 2500              # lmax of CMB for scalar mode
P_k_max_h/Mpc = 10.                # Maximum k for P(k) in 1/Mpc
T_cmb = 2.7255                    # CMB temperature
omega_b = 0.02238280              # Reduced baryon density (Omega*h^2)
YHe = BBN
z_reio = 7.6711                    # Redshift of reionization
k_pivot = 0.05                    # Pivot scale for A_s,n_s
A_s = 2.100549e-09                # Amplitude of prim spectrum
n_s = 0.9660499                   # Spectrum tilt
write_background = yes             # Write background parameter table
input_verbose = 1
background_verbose = 3
thermodynamics_verbose = 1
perturbations_verbose = 1
transfer_verbose = 1
primordial_verbose = 1
harmonic_verbose = 1
fourier_verbose = 1
lensing_verbose = 1
output_verbose = 1